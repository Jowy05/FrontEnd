<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.curling.controller.ReservationManagementController" stylesheets="@../../../style.css">

    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>

    <Label text="Gestión de Reservas" styleClass="section-title"/>

    <HBox spacing="10" alignment="CENTER_LEFT">
        <Label text="Estado:"/>
        <ComboBox fx:id="filterStatus" prefWidth="150"/>
        <DatePicker fx:id="filterDate" promptText="Filtrar por fecha"/>
        <Button text="Filtrar" onAction="#applyFilter" styleClass="button-secondary"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="Refrescar" onAction="#refresh" styleClass="button-secondary"/>
    </HBox>

    <TableView fx:id="tableReservations" VBox.vgrow="ALWAYS">
        <columns>
            <TableColumn fx:id="colDate" text="Fecha/Hora" prefWidth="150"/>
            <TableColumn fx:id="colSheet" text="Pista" prefWidth="60"/>
            <TableColumn fx:id="colPlayer1" text="Jugador 1" prefWidth="150"/>
            <TableColumn fx:id="colPlayer2" text="Jugador 2" prefWidth="150"/>
            <TableColumn fx:id="colStatus" text="Estado" prefWidth="120"/>
        </columns>
    </TableView>

    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="Cancelar Reserva" onAction="#deleteReservation" styleClass="button-danger"/>
    </HBox>

</VBox>
