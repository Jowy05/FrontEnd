<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="10" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="com.curling.controller.ResultManagementController" stylesheets="@../../../style.css">
    
    <padding>
        <Insets bottom="10" left="10" right="10" top="10"/>
    </padding>
    
    <Label text="Gestión de Resultados" styleClass="section-title"/>
    
    <TableView fx:id="tableResults" VBox.vgrow="ALWAYS" prefHeight="250">
        <columns>
            <TableColumn fx:id="colDate" text="Fecha" prefWidth="100"/>
            <TableColumn fx:id="colScore" text="Marcador" prefWidth="80"/>
            <TableColumn fx:id="colWinner" text="Ganador" prefWidth="150"/>
        </columns>
    </TableView>
    
    <GridPane vgap="10" hgap="10">
        <Label text="Marcador:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
        <TextField fx:id="txtScore" promptText="Ej: 8-5" GridPane.rowIndex="0" GridPane.columnIndex="1"/>
        
        <Label text="Comentarios:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
        <TextField fx:id="txtComments" GridPane.rowIndex="1" GridPane.columnIndex="1" GridPane.columnSpan="2"/>
    </GridPane>
    
    <HBox spacing="10" alignment="CENTER_RIGHT">
        <Button text="🔄 Refrescar" onAction="#refresh" styleClass="button-secondary"/>
        <Button text="💾 Actualizar Resultado" onAction="#updateResult" styleClass="button-primary"/>
    </HBox>
</VBox>